---
import Layout from "../layouts/Layout.astro";

// ── Placeholders de contato (fáceis de editar) ──
const WHATSAPP = "https://wa.me/55XXXXXXXXXXX";
const WHATSAPP_MSG =
  "Olá, Jefferson. Gostaria de conversar sobre a proposta para a Superintendência Comercial da nova associação.";
const WHATSAPP_LINK = `${WHATSAPP}?text=${encodeURIComponent(WHATSAPP_MSG)}`;
const EMAIL = "mailto:email@exemplo.com";
---

<Layout>
  <!-- Indicador de progresso da página -->
  <div class="progress" aria-hidden="true"><span id="progress-bar"></span></div>

  <!-- ── NAV ── -->
  <header class="nav" id="topo" data-nav>
    <div class="nav-inner container">
      <a href="#inicio" class="brand" aria-label="Jefferson Lima — início">
        <span class="brand-nome">Jefferson Lima</span>
        <span class="brand-cargo">Superintendência Comercial</span>
      </a>
      <nav class="nav-links" aria-label="Navegação principal">
        <a href="#inicio">Início</a>
        <a href="#mercado">Trajetória</a>
        <a href="#numeros">Resultados</a>
        <a href="#papel">Contribuição</a>
        <a href="#plano">Plano inicial</a>
        <a href="#contato">Contato</a>
      </nav>
      <a href="#contato" class="btn-nav">Falar com Jefferson</a>
      <button class="nav-toggle" type="button" aria-label="Abrir menu" aria-expanded="false" aria-controls="menu-mobile" data-menu-toggle>
        <span aria-hidden="true"></span>
        <span aria-hidden="true"></span>
        <span aria-hidden="true"></span>
      </button>
    </div>
    <!-- Menu mobile -->
    <div class="menu-mobile" id="menu-mobile" data-menu hidden>
      <a href="#inicio">Início</a>
      <a href="#mercado">Trajetória</a>
      <a href="#numeros">Resultados</a>
      <a href="#papel">Contribuição</a>
      <a href="#plano">Plano inicial</a>
      <a href="#contato">Contato</a>
    </div>
  </header>

  <main>
    <!-- ── SEÇÃO 01 — HERO ── -->
    <section id="inicio" class="hero" aria-labelledby="hero-titulo">
      <span class="hero-grid" aria-hidden="true"></span>
      <div class="container hero-inner">
        <div class="hero-texto reveal">
          <p class="eyebrow">Superintendência Comercial</p>
          <h1 id="hero-titulo">
            Mais de 40 anos de experiência para ajudar a construir uma
            associação forte desde o <span class="hl">primeiro dia</span>.
          </h1>
          <p class="hero-sub">
            Jefferson Lima reúne conhecimento da indústria, distribuição, varejo
            e associativismo farmacêutico para liderar a estruturação comercial,
            a expansão e o relacionamento institucional da nova associação de
            redes independentes do Rio de Janeiro.
          </p>
          <div class="hero-id">
            <strong>Jefferson Lima</strong>
            <span>Administrador de Empresas&ensp;|&ensp;MBA em Gestão de Negócios</span>
          </div>
          <div class="hero-acoes">
            <a href="#mercado" class="btn-primario">
              Conheça a trajetória
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M8 3v10M4 9l4 4 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <a href="#contato" class="btn-secundario">Falar com Jefferson</a>
          </div>
        </div>
        <figure class="hero-foto reveal">
          <span class="hero-foto-glow" aria-hidden="true"></span>
          <img
            src="/images/jefferson-hero.jpg"
            alt="Jefferson Lima, executivo do mercado farmacêutico"
            width="700"
            height="600"
            fetchpriority="high"
          />
          <figcaption class="hero-foto-tag">
            <span class="dot" aria-hidden="true"></span>
            Executivo do Mercado Farmacêutico
          </figcaption>
        </figure>
      </div>
    </section>

    <!-- ── SEÇÃO 02 — VISÃO COMPLETA DO MERCADO ── -->
    <section id="mercado" class="bloco" aria-labelledby="mercado-titulo">
      <div class="container">
        <div class="bloco-head reveal">
          <div class="section-label">Trajetória &mdash; Visão completa do mercado</div>
          <h2 id="mercado-titulo">
            Experiência construída em todos os elos da cadeia farmacêutica.
          </h2>
          <p class="section-corpo">
            Ao longo de mais de quatro décadas, Jefferson Lima atuou em posições
            de liderança na indústria farmacêutica, distribuição, varejo e
            desenvolvimento de redes associativistas. Essa visão ampla permite
            compreender as necessidades dos empresários, os interesses da
            indústria, os desafios da distribuição e as oportunidades de
            crescimento coletivo.
          </p>
        </div>

        <div class="cadeia">
          <article class="cadeia-card reveal">
            <span class="cadeia-num">01</span>
            <h3>Indústria</h3>
            <p>
              Início da trajetória como propagandista, avançando até a posição de
              Gerente Regional de Vendas.
            </p>
          </article>
          <article class="cadeia-card reveal">
            <span class="cadeia-num">02</span>
            <h3>Distribuição</h3>
            <p>
              Atuação como Gerente Comercial, Diretor Comercial e Gerente Nacional
              responsável por redes associativistas.
            </p>
          </article>
          <article class="cadeia-card reveal">
            <span class="cadeia-num">03</span>
            <h3>Varejo</h3>
            <p>
              Gestão direta de operações, desenvolvimento comercial e expansão de
              redes de farmácias.
            </p>
          </article>
          <article class="cadeia-card reveal">
            <span class="cadeia-num">04</span>
            <h3>Associativismo</h3>
            <p>
              Atração de associados, negociação com parceiros e criação de
              oportunidades comerciais para redes independentes.
            </p>
          </article>
        </div>
      </div>
    </section>

    <!-- ── SEÇÃO 03 — NÚMEROS DE IMPACTO ── -->
    <section id="numeros" class="numeros" aria-labelledby="numeros-titulo">
      <span class="numeros-grid" aria-hidden="true"></span>
      <div class="container">
        <div class="bloco-head reveal">
          <div class="section-label section-label--claro">Resultados</div>
          <h2 id="numeros-titulo" class="tx-claro">
            Resultados que comprovam a experiência.
          </h2>
        </div>

        <div class="numeros-grade">
          <div class="num-card reveal">
            <div class="num-valor">
              <span class="num" data-count="60">60</span>
              <span class="num-seta" aria-hidden="true">→</span>
              <span class="num num--alvo" data-count="246">246</span>
              <span class="num-unid">lojas</span>
            </div>
            <p>
              Participação direta na expansão da Rede Drogarias Max, contribuindo
              para o crescimento e fortalecimento da rede de lojas franqueadas.
            </p>
          </div>
          <div class="num-card reveal">
            <div class="num-valor">
              <span class="num" data-count="22">22</span>
              <span class="num-seta" aria-hidden="true">→</span>
              <span class="num num--alvo" data-count="40">40</span>
              <span class="num-unid">lojas</span>
            </div>
            <p>
              Oito anos de atuação na gestão e expansão de uma operação direta de
              varejo farmacêutico.
            </p>
          </div>
          <div class="num-card reveal">
            <div class="num-valor">
              <span class="num" data-count="130">130</span><span class="num-mais">+</span>
              <span class="num-unid">profissionais</span>
            </div>
            <p>
              Liderança de estruturas comerciais com mais de 100 vendedores e 30
              operadores de televendas.
            </p>
          </div>
          <div class="num-card reveal">
            <div class="num-valor">
              <span class="num" data-count="17">17</span>
              <span class="num-unid">anos</span>
            </div>
            <p>
              Atuação como Diretor Comercial de uma distribuidora regional,
              liderando negociações e parcerias com indústrias nacionais e
              multinacionais.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ── SEÇÃO 04 — PAPEL COMO SUPERINTENDENTE COMERCIAL ── -->
    <section id="papel" class="bloco" aria-labelledby="papel-titulo">
      <div class="container">
        <div class="bloco-head reveal">
          <div class="section-label">Contribuição &mdash; Como Superintendente Comercial</div>
          <h2 id="papel-titulo">Liderança comercial do planejamento à execução.</h2>
          <p class="section-corpo">
            Como Superintendente Comercial, Jefferson poderá liderar a
            estruturação da área comercial da associação, integrando estratégia,
            relacionamento, negociação, expansão e desenvolvimento de associados.
          </p>
        </div>

        <ol class="frentes" aria-label="Frentes de atuação">
          <li class="frente reveal">
            <span class="frente-passo">01</span>
            <div class="frente-corpo">
              <h3>Estruturação comercial</h3>
              <p>
                Criação do planejamento, metas, processos, indicadores e rotinas
                de acompanhamento da associação.
              </p>
            </div>
          </li>
          <li class="frente reveal">
            <span class="frente-passo">02</span>
            <div class="frente-corpo">
              <h3>Desenvolvimento de associados</h3>
              <p>
                Prospecção de novas redes, aproximação com empresários e
                fortalecimento do relacionamento com os associados.
              </p>
            </div>
          </li>
          <li class="frente reveal">
            <span class="frente-passo">03</span>
            <div class="frente-corpo">
              <h3>Negociação estratégica</h3>
              <p>
                Construção de acordos comerciais, verbas de trade, projetos de
                mídia e oportunidades conjuntas.
              </p>
            </div>
          </li>
          <li class="frente reveal">
            <span class="frente-passo">04</span>
            <div class="frente-corpo">
              <h3>Relações institucionais</h3>
              <p>
                Representação da associação junto à indústria, distribuição,
                entidades e principais lideranças do setor.
              </p>
            </div>
          </li>
          <li class="frente reveal">
            <span class="frente-passo">05</span>
            <div class="frente-corpo">
              <h3>Geração de valor</h3>
              <p>
                Transformação da força coletiva dos associados em melhores
                condições comerciais, novas receitas e maior competitividade.
              </p>
            </div>
          </li>
        </ol>
      </div>
    </section>

    <!-- ── SEÇÃO 05 — EXPERIÊNCIA EM ASSOCIATIVISMO ── -->
    <section id="associativismo" class="bloco bloco--cinza" aria-labelledby="assoc-titulo">
      <div class="container assoc-inner">
        <div class="assoc-texto reveal">
          <div class="section-label">Associativismo na prática</div>
          <h2 id="assoc-titulo">
            Conhecimento prático de como uma rede cresce e gera valor.
          </h2>
          <p>
            Jefferson foi o primeiro gestor de negócios da Rede Drogarias Max,
            participando diretamente de sua expansão de 60 para 246 lojas.
          </p>
          <p>
            Também esteve envolvido na criação e implantação, no Rio de Janeiro,
            de um modelo de captação de verbas de mídia e recursos institucionais
            para a Maxcenter, desenvolvido a partir de uma iniciativa discutida
            com Paulo Panarello.
          </p>
          <p>
            Posteriormente, na Panarello, atuou como Gerente Comercial e Gerente
            Nacional responsável pelas redes ligadas ao associativismo.
          </p>
        </div>

        <ol class="timeline reveal" aria-label="Linha do tempo resumida">
          <li>
            <span class="tl-dot" aria-hidden="true"></span>
            <div>
              <strong>Rede Drogarias Max</strong>
              <span>Primeiro gestor de negócios &middot; expansão de 60 → 246 lojas</span>
            </div>
          </li>
          <li>
            <span class="tl-dot" aria-hidden="true"></span>
            <div>
              <strong>Maxcenter</strong>
              <span>Modelo de captação de verbas de mídia e recursos institucionais (RJ)</span>
            </div>
          </li>
          <li>
            <span class="tl-dot" aria-hidden="true"></span>
            <div>
              <strong>Panarello</strong>
              <span>Gerente Comercial e Gerente Nacional das redes de associativismo</span>
            </div>
          </li>
          <li>
            <span class="tl-dot" aria-hidden="true"></span>
            <div>
              <strong>Varejo</strong>
              <span>Gestão direta e expansão de operação de farmácias</span>
            </div>
          </li>
          <li>
            <span class="tl-dot" aria-hidden="true"></span>
            <div>
              <strong>Distribuição regional</strong>
              <span>17 anos como Diretor Comercial</span>
            </div>
          </li>
        </ol>
      </div>
    </section>

    <!-- ── SEÇÃO 06 — PLANO INICIAL DE ATUAÇÃO ── -->
    <section id="plano" class="bloco" aria-labelledby="plano-titulo">
      <div class="container">
        <div class="bloco-head reveal">
          <div class="section-label">Plano inicial de atuação</div>
          <h2 id="plano-titulo">Dos primeiros alinhamentos à ativação comercial.</h2>
          <p class="section-corpo">
            Uma visão inicial para transformar a ideia da associação em estrutura,
            agenda comercial e capacidade de execução.
          </p>
        </div>

        <div class="fases">
          <article class="fase reveal">
            <header>
              <span class="fase-tag">Fase 01</span>
              <span class="fase-prazo">Primeiros 30 dias</span>
            </header>
            <h3>Escuta e diagnóstico</h3>
            <ul role="list">
              <li>Escuta dos empresários fundadores.</li>
              <li>Compreensão dos objetivos da associação.</li>
              <li>Mapeamento das redes e empresários prioritários.</li>
              <li>Levantamento de parceiros estratégicos.</li>
              <li>Definição da proposta de valor inicial.</li>
            </ul>
          </article>
          <article class="fase reveal">
            <header>
              <span class="fase-tag">Fase 02</span>
              <span class="fase-prazo">De 31 a 60 dias</span>
            </header>
            <h3>Estruturação comercial</h3>
            <ul role="list">
              <li>Desenvolvimento do plano comercial.</li>
              <li>Criação do modelo de atração de associados.</li>
              <li>Organização do pipeline de negociações.</li>
              <li>Construção da agenda com indústria e distribuição.</li>
              <li>Definição dos principais indicadores.</li>
            </ul>
          </article>
          <article class="fase reveal">
            <header>
              <span class="fase-tag">Fase 03</span>
              <span class="fase-prazo">De 61 a 100 dias</span>
            </header>
            <h3>Ativação e execução</h3>
            <ul role="list">
              <li>Início da prospecção estruturada.</li>
              <li>Apresentação da associação ao mercado.</li>
              <li>Desenvolvimento das primeiras negociações comerciais.</li>
              <li>Ativação dos projetos prioritários.</li>
              <li>Acompanhamento dos primeiros resultados.</li>
            </ul>
          </article>
        </div>
        <p class="plano-obs reveal">
          Visão preliminar de trabalho, sujeita ao alinhamento com o grupo de
          empresários. Não se trata de uma promessa fechada.
        </p>
      </div>
    </section>

    <!-- ── SEÇÃO 07 — RELACIONAMENTO INSTITUCIONAL ── -->
    <section id="relacionamento" class="bloco bloco--cinza" aria-labelledby="rel-titulo">
      <div class="container">
        <div class="bloco-head reveal">
          <div class="section-label">Relacionamento institucional</div>
          <h2 id="rel-titulo">
            Credibilidade construída ao longo de mais de quatro décadas.
          </h2>
          <p class="section-corpo">
            Ao longo de sua trajetória, Jefferson construiu relacionamento com
            presidentes de entidades do varejo associativista, empresários de
            redes, executivos de distribuidoras nacionais e regionais e
            lideranças comerciais das principais indústrias farmacêuticas do país.
            Também participou de forma recorrente dos principais encontros, feiras
            e eventos estratégicos do setor.
          </p>
        </div>

        <div class="universos">
          <article class="universo reveal">
            <span class="universo-icon" aria-hidden="true">
              <svg viewBox="0 0 32 32" fill="none"><path d="M5 27V11l7-4 7 4v16M19 27V15l8-4v16M5 27h22M9 14v2M9 19v2M15 14v2M15 19v2M23 18v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            <h3>Indústria</h3>
            <p>Lideranças comerciais das principais indústrias farmacêuticas.</p>
          </article>
          <article class="universo reveal">
            <span class="universo-icon" aria-hidden="true">
              <svg viewBox="0 0 32 32" fill="none"><path d="M3 12h17v9H3zM20 15h5l4 4v2h-9zM8.5 24a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5ZM23.5 24a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
            </span>
            <h3>Distribuição</h3>
            <p>Executivos de distribuidoras nacionais e regionais.</p>
          </article>
          <article class="universo reveal">
            <span class="universo-icon" aria-hidden="true">
              <svg viewBox="0 0 32 32" fill="none"><path d="M5 11h22l-1.5 15a2 2 0 0 1-2 1.8H8.5a2 2 0 0 1-2-1.8L5 11ZM11 11V8a5 5 0 0 1 10 0v3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            <h3>Varejo</h3>
            <p>Empresários de redes e operações de farmácias.</p>
          </article>
          <article class="universo reveal">
            <span class="universo-icon" aria-hidden="true">
              <svg viewBox="0 0 32 32" fill="none"><circle cx="16" cy="9" r="4" stroke="currentColor" stroke-width="1.5"/><circle cx="7" cy="21" r="3.5" stroke="currentColor" stroke-width="1.5"/><circle cx="25" cy="21" r="3.5" stroke="currentColor" stroke-width="1.5"/><path d="M14 12.5 9 18M18 12.5l5 5.5M10.5 21h11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </span>
            <h3>Associativismo</h3>
            <p>Presidentes de entidades do varejo associativista.</p>
          </article>
        </div>
      </div>
    </section>

    <!-- ── SEÇÃO 08 — ENCERRAMENTO ── -->
    <section id="contato" class="fechamento" aria-labelledby="fech-titulo">
      <span class="hero-grid" aria-hidden="true"></span>
      <div class="container fechamento-inner reveal">
        <div class="section-label section-label--claro">Encerramento</div>
        <h2 id="fech-titulo" class="tx-claro">
          Uma nova associação precisa nascer com visão, relacionamento e
          capacidade de execução.
        </h2>
        <p class="fechamento-texto">
          Jefferson Lima coloca sua experiência à disposição do grupo de
          empresários responsável pela criação da nova associação, com a missão
          de cooperar com sua estruturação comercial, desenvolver associados,
          construir parcerias e transformar força coletiva em resultados.
        </p>

        <div class="assinatura">
          <strong>Jefferson Lima</strong>
          <span>Administrador de Empresas</span>
          <span>MBA em Gestão de Negócios</span>
          <span>Executivo do Mercado Farmacêutico</span>
        </div>

        <div class="fechamento-acoes">
          <a href={EMAIL} class="btn-primario btn-primario--claro">
            Conversar com Jefferson
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href={WHATSAPP_LINK} class="btn-whats" target="_blank" rel="noopener">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.84 9.84 0 0 0 12.04 2Zm5.8 14.13c-.25.7-1.44 1.33-1.99 1.41-.53.08-1.17.11-1.89-.12-.43-.14-.99-.32-1.7-.63-2.99-1.29-4.94-4.3-5.09-4.5-.15-.2-1.22-1.62-1.22-3.09 0-1.47.77-2.2 1.04-2.5.27-.3.59-.37.79-.37l.57.01c.18 0 .43-.07.67.51.25.6.84 2.07.91 2.22.07.15.12.32.02.52-.1.2-.15.32-.3.5-.15.18-.31.4-.45.53-.15.15-.3.31-.13.6.17.3.76 1.25 1.63 2.02 1.12.99 2.07 1.3 2.37 1.45.3.15.47.12.65-.07.18-.2.74-.86.94-1.16.2-.3.4-.25.67-.15.27.1 1.71.81 2 .96.3.15.5.22.57.35.07.12.07.72-.18 1.42Z"/>
            </svg>
            Enviar mensagem pelo WhatsApp
          </a>
        </div>
      </div>
    </section>
  </main>

  <!-- ── FOOTER ── -->
  <footer class="footer">
    <div class="container footer-inner">
      <div class="footer-brand">
        <strong>Jefferson Lima</strong>
        <span>Superintendência Comercial &middot; Mercado Farmacêutico</span>
      </div>
      <nav class="footer-links" aria-label="Navegação do rodapé">
        <a href="#inicio">Início</a>
        <a href="#mercado">Trajetória</a>
        <a href="#numeros">Resultados</a>
        <a href="#papel">Contribuição</a>
        <a href="#plano">Plano inicial</a>
        <a href="#contato">Contato</a>
      </nav>
      <p class="footer-legal">
        &copy; <span id="ano">2026</span> Jefferson Lima. Apresentação de posicionamento executivo.
      </p>
    </div>
  </footer>

  <!-- Botão flutuante de WhatsApp -->
  <a
    href={WHATSAPP_LINK}
    class="whats-float"
    target="_blank"
    rel="noopener"
    aria-label="Falar com Jefferson pelo WhatsApp"
  >
    <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
