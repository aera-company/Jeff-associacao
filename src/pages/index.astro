---
import Layout from "../layouts/Layout.astro";
const year = new Date().getFullYear();
---

<Layout
  title="MERUS — Tratamento Físico de Fluidos para Oil & Gas"
  description="O anel MERUS previne incrustação, corrosão e biofouling em sistemas de fluido industrial e offshore. Sem químicos, sem paradas, sem alteração de processo. Fabricado na Alemanha."
>

  <!-- ── NAV ── -->
  <header class="nav" id="topo">
    <div class="nav-inner container">
      <a href="#topo" class="logo" aria-label="MERUS — página inicial">
        <img src="/merus-logo2.svg" alt="MERUS" width="100" height="48" />
        <span class="logo-sep" aria-hidden="true"></span>
        <img src="/gavea-green.png" alt="Gavea Green" class="logo-gavea" width="92" height="48" />
      </a>
      <nav class="nav-links" aria-label="Navegação principal">
        <a href="#solucao">Solução</a>
        <a href="#tecnologia">Tecnologia</a>
        <a href="#aplicacoes">Aplicações</a>
        <a href="#clientes">Clientes</a>
      </nav>
      <a href="#contato" class="btn-nav">Solicitar Avaliação</a>
    </div>
  </header>

  <!-- ── HERO ── -->
  <div class="video-stage" id="vstage">
    <div class="video-bg" aria-hidden="true">
      <video id="bgvideo" src="/video-merus-v3.mp4" muted playsinline preload="auto"></video>
    </div>

  <section id="hero" aria-labelledby="hero-titulo">
    <div class="container hero-inner">

      <div class="hero-texto">
        <p class="eyebrow">Fabricado na Alemanha &mdash; Oil &amp; Gas / Industrial</p>
        <h1 id="hero-titulo">Keeps your pipes clean.</h1>
        <p class="hero-sub">Tubos livres de incrustações</p>
        <p class="hero-corpo">
          Instalado externamente à tubulação, o MERUS Ring transmite oscilações
          físicas para a água, ajudando a reduzir depósitos, corrosão e biofilme no sistema.
        </p>
        <ul class="hero-bullets" role="list">
          <li>Menos manutenção.</li>
          <li>Mais eficiência.</li>
          <li>Maior vida útil.</li>
        </ul>
        <div class="hero-acoes">
          <a href="#contato" class="btn-primario">
            Solicitar avaliação técnica
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
        <div class="mig-hero">
          <img src="/made-in-germany.png" alt="Made in Germany" width="110" height="44" loading="eager" />
        </div>
      </div>

    </div>
  </section>

  <!-- ── SOLUÇÃO ── -->
  <section id="solucao" aria-labelledby="sol-titulo">
    <div class="container">
      <div class="section-label">01 &mdash; Solução</div>
      <h2 id="sol-titulo">Menos impacto,<br>mais eficiência.</h2>
      <div class="sol-layout">
        <div class="sol-corpo">
          <p>
            Tecnologia alemã para tratamento de água, com alta eficiência
            operacional e menor impacto ambiental.
          </p>
        </div>
        <ul class="sol-bullets" role="list">
          <li>Sem químicos.</li>
          <li>Sem consumo de energia.</li>
          <li>Sem manutenção recorrente.</li>
          <li>05 anos de duração.</li>
        </ul>
      </div>
    </div>
  </section>
  </div><!-- /video-stage -->

  <!-- ── FAIXA DE INDICADORES ── -->
  <section class="faixa-stats" aria-label="Indicadores MERUS">
    <div class="container faixa-inner">
      <div class="faixa-item">
        <span class="faixa-n">70+</span>
        <span class="faixa-l">Países</span>
      </div>
      <span class="faixa-sep" aria-hidden="true"></span>
      <div class="faixa-item">
        <span class="faixa-n">25+</span>
        <span class="faixa-l">Anos em campo</span>
      </div>
      <span class="faixa-sep" aria-hidden="true"></span>
      <div class="faixa-item">
        <span class="faixa-n">0</span>
        <span class="faixa-l">Químicos adicionados</span>
      </div>
      <span class="faixa-sep" aria-hidden="true"></span>
      <div class="faixa-item">
        <span class="faixa-n">90%</span>
        <span class="faixa-l">Menos incrustações</span>
      </div>
    </div>
  </section>

  <!-- ── TECNOLOGIA ── -->
  <section id="tecnologia" aria-labelledby="tec-titulo">
    <div class="container">

      <div class="tec-top">
        <div class="tec-texto">
          <div class="section-label">02 &mdash; A Tecnologia</div>
          <h2 id="tec-titulo">Como o MERUS funciona</h2>
          <p>
            O MERUS Ring é instalado ao redor da tubulação e transmite oscilações
            físicas para a água através da parede do tubo. Essas oscilações influenciam
            o comportamento das partículas no fluxo, contribuindo para maior solubilidade
            e menor formação de depósitos.
          </p>
          <div class="tec-destaque">
            <strong>Instalado na infraestrutura existente</strong>
            <span>Sem modificação de tubulação, soldagem ou penetração.</span>
          </div>
        </div>

        <figure class="tec-video">
          <video
            src="/merus-agua.mp4"
            autoplay loop muted playsinline preload="metadata"
          ></video>
        </figure>
      </div>

      <div class="data-callout" aria-label="Comparativo de taxa de corrosão em campo">
        <div class="data-grid">
          <div class="data-block">
            <span class="data-n">1.03</span>
            <span class="data-unit">MPY</span>
            <span class="data-label">Com MERUS</span>
            <span class="data-sub">Trocador 101-E9A</span>
          </div>
          <div class="data-vs" aria-hidden="true">vs</div>
          <div class="data-block data-block--ruim">
            <span class="data-n">2.87</span>
            <span class="data-unit">MPY</span>
            <span class="data-label">Sem MERUS</span>
            <span class="data-sub">Trocador 101-E9B</span>
          </div>
        </div>
        <p class="data-note">
          Mesmo sistema, mesma plataforma, mesmo fluido.
          Monitoramento de campo por 3 meses. Resultados refletem as condições da instalação monitorada.
        </p>
      </div>

    </div>
  </section>

  <!-- ── RESULTADOS (ANTES E DEPOIS) ── -->
  <section id="resultados" aria-labelledby="res-titulo" class="sec-cinza">
    <div class="container">
      <div class="section-label">03 &mdash; Antes e Depois</div>
      <h2 id="res-titulo">Menos incrustação.<br>Mais eficiência no fluxo.</h2>
      <p class="section-corpo">
        A atuação do MERUS contribui para superfícies internas mais limpas,
        menor acúmulo de depósitos e melhor estabilidade operacional.
      </p>

      <div class="ba-grid">

        <div class="ba-card">
          <div class="ba" style="--pos:50%">
            <img class="ba-img" src="/heat-enchance-depois.png" alt="Trocador de calor após o MERUS: superfície mais limpa" loading="lazy" width="700" height="525" />
            <img class="ba-img ba-img--antes" src="/heat-enchance-antes.png" alt="Trocador de calor antes do MERUS: depósitos acumulados" loading="lazy" width="700" height="525" />
            <span class="ba-tag ba-tag--antes">Antes</span>
            <span class="ba-tag ba-tag--depois">Depois</span>
            <div class="ba-line" aria-hidden="true">
              <span class="ba-grip">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M6 4L2 8l4 4M10 4l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </div>
            <input class="ba-range" type="range" min="0" max="100" value="50" aria-label="Comparar antes e depois — trocador de calor" />
          </div>
          <div class="ba-legendas">
            <p><strong>Antes</strong> Depósitos acumulados e redução da passagem interna.</p>
            <p><strong>Depois</strong> Superfície mais limpa e melhor condição de fluxo.</p>
          </div>
        </div>

        <div class="ba-card">
          <div class="ba" style="--pos:50%">
            <img class="ba-img" src="/corrosao-depois.png" alt="Tubulação após o MERUS: menor acúmulo e corrosão" loading="lazy" width="700" height="525" />
            <img class="ba-img ba-img--antes" src="/corrosao-antes.png" alt="Tubulação antes do MERUS: corrosão e biofilme" loading="lazy" width="700" height="525" />
            <span class="ba-tag ba-tag--antes">Antes</span>
            <span class="ba-tag ba-tag--depois">Depois</span>
            <div class="ba-line" aria-hidden="true">
              <span class="ba-grip">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M6 4L2 8l4 4M10 4l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </div>
            <input class="ba-range" type="range" min="0" max="100" value="50" aria-label="Comparar antes e depois — corrosão e biofilme" />
          </div>
          <div class="ba-legendas">
            <p><strong>Antes</strong> Corrosão visível e formação de biofilme no sistema.</p>
            <p><strong>Depois</strong> Menor acúmulo, melhor estabilidade e manutenção reduzida.</p>
          </div>
        </div>

        <div class="ba-card">
          <div class="ba" style="--pos:50%">
            <img class="ba-img" src="/steam-boiler-depois.png" alt="Caldeira após o MERUS: superfície tratada" loading="lazy" width="700" height="525" />
            <img class="ba-img ba-img--antes" src="/steam-boiler-antes.png" alt="Caldeira antes do MERUS: incrustação na superfície" loading="lazy" width="700" height="525" />
            <span class="ba-tag ba-tag--antes">Antes</span>
            <span class="ba-tag ba-tag--depois">Depois</span>
            <div class="ba-line" aria-hidden="true">
              <span class="ba-grip">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M6 4L2 8l4 4M10 4l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </div>
            <input class="ba-range" type="range" min="0" max="100" value="50" aria-label="Comparar antes e depois — caldeira a vapor" />
          </div>
          <div class="ba-legendas">
            <p><strong>Antes</strong> Incrustação e perda de eficiência térmica.</p>
            <p><strong>Depois</strong> Superfície tratada e melhor desempenho operacional.</p>
          </div>
        </div>

      </div>

      <p class="res-apoio">
        Mais do que tratar a água, o MERUS ajuda a preservar a eficiência
        do sistema ao longo do tempo.
      </p>
      <p class="res-micro">
        Resultados podem variar conforme fluido, material, histórico do sistema e condições operacionais.
      </p>
    </div>
  </section>

  <!-- ── APLICAÇÕES ── -->
  <section id="aplicacoes" aria-labelledby="ap-titulo">
    <div class="container">
      <div class="section-label">04 &mdash; Aplicações</div>
      <h2 id="ap-titulo">
        Aplicado em infraestrutura<br>crítica de Oil &amp; Gas.
      </h2>
      <p class="section-corpo">
        O MERUS atua no nível de componente e sistema, endereçando problemas de
        qualidade de fluidos em toda a cadeia de produção e processamento.
      </p>
      <div class="apps-slider" id="apps-slider" role="list">

        <article class="app-card" style="--card-img:url('/cards/trocadores-de-calor.png')" role="listitem" tabindex="0">
          <div class="app-card__inner">
            <div class="app-card__face app-card__front">
              <span class="app-card__icon" aria-hidden="true"><svg viewBox="0 0 40 40" fill="none"><rect x="4" y="13" width="32" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/><line x1="10" y1="13" x2="10" y2="27" stroke="currentColor" stroke-width="1.5"/><line x1="16" y1="13" x2="16" y2="27" stroke="currentColor" stroke-width="1.5"/><line x1="22" y1="13" x2="22" y2="27" stroke="currentColor" stroke-width="1.5"/><line x1="28" y1="13" x2="28" y2="27" stroke="currentColor" stroke-width="1.5"/><line x1="4" y1="20" x2="2" y2="20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><line x1="36" y1="20" x2="38" y2="20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></span>
              <div class="app-card__txt">
                <h3>Trocadores de Calor</h3>
                <p>Eficiência térmica preservada, com menos limpeza química.</p>
              </div>
              <span class="app-card__flip" aria-hidden="true"><svg width="13" height="13" viewBox="0 0 16 16" fill="none"><path d="M2 8a6 6 0 0 1 10-4.5M14 8a6 6 0 0 1-10 4.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/><path d="M12 2v2.5H9.5M4 14v-2.5H6.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>Ver imagem</span>
            </div>
            <div class="app-card__face app-card__back">
              <div class="app-card__img" aria-hidden="true"></div>
            </div>
          </div>
        </article>

        <article class="app-card" style="--card-img:url('/cards/linhas-de-fluxo-risers.png')" role="listitem" tabindex="0">
          <div class="app-card__inner">
            <div class="app-card__face app-card__front">
              <span class="app-card__icon" aria-hidden="true"><svg viewBox="0 0 40 40" fill="none"><line x1="2" y1="17" x2="38" y2="17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><line x1="2" y1="23" x2="38" y2="23" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><rect x="16" y="14" width="8" height="12" rx="2" stroke="currentColor" stroke-width="1.5" fill="none"/></svg></span>
              <div class="app-card__txt">
                <h3>Linhas de Fluxo e Risers</h3>
                <p>Menos cera e incrustação em linhas subsea e topside.</p>
              </div>
              <span class="app-card__flip" aria-hidden="true"><svg width="13" height="13" viewBox="0 0 16 16" fill="none"><path d="M2 8a6 6 0 0 1 10-4.5M14 8a6 6 0 0 1-10 4.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/><path d="M12 2v2.5H9.5M4 14v-2.5H6.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>Ver imagem</span>
            </div>
            <div class="app-card__face app-card__back">
              <div class="app-card__img" aria-hidden="true"></div>
            </div>
          </div>
        </article>

        <article class="app-card" style="--card-img:url('/cards/separadores.png')" role="listitem" tabindex="0">
          <div class="app-card__inner">
            <div class="app-card__face app-card__front">
              <span class="app-card__icon" aria-hidden="true"><svg viewBox="0 0 40 40" fill="none"><rect x="6" y="8" width="28" height="24" rx="3" stroke="currentColor" stroke-width="1.5"/><line x1="6" y1="20" x2="34" y2="20" stroke="currentColor" stroke-width="1" opacity="0.45"/><path d="M13 8L13 4 M27 8L27 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M17 32L17 36 M23 32L23 36" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></span>
              <div class="app-card__txt">
                <h3>Separadores</h3>
                <p>Melhor separação óleo-água-gás, com menos emulsão.</p>
              </div>
              <span class="app-card__flip" aria-hidden="true"><svg width="13" height="13" viewBox="0 0 16 16" fill="none"><path d="M2 8a6 6 0 0 1 10-4.5M14 8a6 6 0 0 1-10 4.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/><path d="M12 2v2.5H9.5M4 14v-2.5H6.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>Ver imagem</span>
            </div>
            <div class="app-card__face app-card__back">
              <div class="app-card__img" aria-hidden="true"></div>
            </div>
          </div>
        </article>

        <article class="app-card" style="--card-img:url('/cards/captacao-agua-mar.png')" role="listitem" tabindex="0">
          <div class="app-card__inner">
            <div class="app-card__face app-card__front">
              <span class="app-card__icon" aria-hidden="true"><svg viewBox="0 0 40 40" fill="none"><path d="M7 28Q13 20 20 24Q27 28 33 20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M7 34Q13 26 20 30Q27 34 33 26" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.4"/><path d="M20 5L20 17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M15 10L20 5L25 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
              <div class="app-card__txt">
                <h3>Captação de Água do Mar</h3>
                <p>Controle do crescimento marinho em telas e filtros.</p>
              </div>
              <span class="app-card__flip" aria-hidden="true"><svg width="13" height="13" viewBox="0 0 16 16" fill="none"><path d="M2 8a6 6 0 0 1 10-4.5M14 8a6 6 0 0 1-10 4.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/><path d="M12 2v2.5H9.5M4 14v-2.5H6.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>Ver imagem</span>
            </div>
            <div class="app-card__face app-card__back">
              <div class="app-card__img" aria-hidden="true"></div>
            </div>
          </div>
        </article>

        <article class="app-card" style="--card-img:url('/cards/loops-de-resfriamento.png')" role="listitem" tabindex="0">
          <div class="app-card__inner">
            <div class="app-card__face app-card__front">
              <span class="app-card__icon" aria-hidden="true"><svg viewBox="0 0 40 40" fill="none"><circle cx="20" cy="20" r="13" stroke="currentColor" stroke-width="1.5" stroke-dasharray="3 2"/><circle cx="20" cy="20" r="6" stroke="currentColor" stroke-width="1.5"/><path d="M20 7L20 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M26 14L22 20L26 26" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
              <div class="app-card__txt">
                <h3>Loops de Resfriamento</h3>
                <p>Troca térmica estável e manutenção mais espaçada.</p>
              </div>
              <span class="app-card__flip" aria-hidden="true"><svg width="13" height="13" viewBox="0 0 16 16" fill="none"><path d="M2 8a6 6 0 0 1 10-4.5M14 8a6 6 0 0 1-10 4.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/><path d="M12 2v2.5H9.5M4 14v-2.5H6.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>Ver imagem</span>
            </div>
            <div class="app-card__face app-card__back">
              <div class="app-card__img" aria-hidden="true"></div>
            </div>
          </div>
        </article>

        <article class="app-card" style="--card-img:url('/cards/plataformas-offshore.png')" role="listitem" tabindex="0">
          <div class="app-card__inner">
            <div class="app-card__face app-card__front">
              <span class="app-card__icon" aria-hidden="true"><svg viewBox="0 0 40 40" fill="none"><rect x="10" y="14" width="20" height="14" rx="1" stroke="currentColor" stroke-width="1.5"/><line x1="14" y1="14" x2="14" y2="9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><line x1="26" y1="14" x2="26" y2="9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><line x1="10" y1="28" x2="6" y2="35" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><line x1="30" y1="28" x2="34" y2="35" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><line x1="20" y1="28" x2="20" y2="35" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><line x1="3" y1="35" x2="37" y2="35" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></span>
              <div class="app-card__txt">
                <h3>Plataformas Offshore</h3>
                <p>Sistema completo tratado, sem logística química.</p>
              </div>
              <span class="app-card__flip" aria-hidden="true"><svg width="13" height="13" viewBox="0 0 16 16" fill="none"><path d="M2 8a6 6 0 0 1 10-4.5M14 8a6 6 0 0 1-10 4.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/><path d="M12 2v2.5H9.5M4 14v-2.5H6.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>Ver imagem</span>
            </div>
            <div class="app-card__face app-card__back">
              <div class="app-card__img" aria-hidden="true"></div>
            </div>
          </div>
        </article>

        <article class="app-card" style="--card-img:url('/cards/agua-produzida.png')" role="listitem" tabindex="0">
          <div class="app-card__inner">
            <div class="app-card__face app-card__front">
              <span class="app-card__icon" aria-hidden="true"><svg viewBox="0 0 40 40" fill="none"><rect x="6" y="13" width="28" height="18" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M14 13L14 7L22 7L22 13" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><line x1="6" y1="22" x2="34" y2="22" stroke="currentColor" stroke-width="1" stroke-dasharray="2 2" opacity="0.4"/><circle cx="20" cy="27" r="2" stroke="currentColor" stroke-width="1.2"/></svg></span>
              <div class="app-card__txt">
                <h3>Água Produzida</h3>
                <p>Menos incrustação e biofouling em reinjeção e descarte.</p>
              </div>
              <span class="app-card__flip" aria-hidden="true"><svg width="13" height="13" viewBox="0 0 16 16" fill="none"><path d="M2 8a6 6 0 0 1 10-4.5M14 8a6 6 0 0 1-10 4.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/><path d="M12 2v2.5H9.5M4 14v-2.5H6.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>Ver imagem</span>
            </div>
            <div class="app-card__face app-card__back">
              <div class="app-card__img" aria-hidden="true"></div>
            </div>
          </div>
        </article>

